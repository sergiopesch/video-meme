# Shared development settings
PORT=5000
CLIENT_URL=http://localhost:5173

# Upload and render pipeline
MAX_UPLOAD_SIZE=52428800
TENOR_API_KEY=
TENOR_CLIENT_KEY=video-meme
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf

# Optional overrides if you want storage elsewhere
# PUBLIC_DIR=./server/public
# UPLOADS_DIR=./server/uploads
# OUTPUT_DIR=./server/public/output
# JOBS_DIR=./server/uploads/jobs

# Frontend API configuration
# VITE_API_BASE_URL=https://your-api.example.com
# VITE_API_PROXY_TARGET=http://127.0.0.1:5000
